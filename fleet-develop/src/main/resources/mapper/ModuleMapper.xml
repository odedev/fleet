<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.odes.fleet.develop.mapper.ModuleMapper">
  <sql id="tableColumn">
    `develop_module`.`id`,
    `develop_module`.`code`,
    `develop_module`.`name`,
    `develop_module`.`description`,
    `develop_module`.`module_type`,
    `develop_module`.`storage_type`
  </sql>
  <sql id="column">
    `id`,
    `code`,
    `name`,
    `description`,
    `module_type`,
    `storage_type`
  </sql>

  <sql id="insertColumn">
    <trim suffixOverrides=",">
      `id`,
      <if test="code != null">`code`,</if>
      <if test="name != null">`name`,</if>
      <if test="description != null">`description`,</if>
      <if test="moduleType != null">`module_type`,</if>
      <if test="storageType != null">`storage_type`,</if>
    </trim>
  </sql>
  <sql id="insertValue">
    <trim suffixOverrides=",">
      #{id},
      <if test="code != null">#{code},</if>
      <if test="name != null">#{name},</if>
      <if test="description != null">#{description},</if>
      <if test="moduleType != null">#{moduleType},</if>
      <if test="storageType != null">#{storageType},</if>
    </trim>
  </sql>
  <sql id="insertEntityValue">
    <trim suffixOverrides=",">
      #{module.id},
      <if test="module.code != null">#{module.code},</if>
      <if test="module.name != null">#{module.name},</if>
      <if test="module.description != null">#{module.description},</if>
      <if test="module.moduleType != null">#{module.moduleType},</if>
      <if test="module.storageType != null">#{module.storageType},</if>
    </trim>
  </sql>

  <sql id="updateColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="code != null">`code` = #{code},</if>
      <if test="name != null">`name` = #{name},</if>
      <if test="email != null">`email` = #{email},</if>
      <if test="phone != null">`phone` = #{phone},</if>
      <if test="type != null">`type` = #{type},</if>
      <if test="status != null">`status` = #{status},</if>
      <if test="isAdmin != null">`is_admin` = #{isAdmin},</if>
    </trim>
  </sql>
  <sql id="updateEntityColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="module.code != null">`code` = #{module.code},</if>
      <if test="module.name != null">`name` = #{module.name},</if>
      <if test="module.email != null">`email` = #{module.email},</if>
      <if test="module.phone != null">`phone` = #{module.phone},</if>
      <if test="module.type != null">`type` = #{module.type},</if>
      <if test="module.status != null">`status` = #{module.status},</if>
      <if test="module.isAdmin != null">`is_admin` = #{module.isAdmin},</if>
    </trim>
  </sql>

  <sql id="deleteColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="deletedAt != null">`deleted_at` = #{deletedAt},</if>
    </trim>
  </sql>
  <sql id="deleteEntityColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="module.deletedAt != null">`deleted_at` = #{module.deletedAt},</if>
    </trim>
  </sql>

  <resultMap id="resultMap" type="dev.odes.fleet.develop.entity.Module">
    <id property="id" column="id"/>
    <result property="code" column="code"/>
    <result property="name" column="name"/>
    <result property="email" column="email"/>
    <result property="phone" column="phone"/>
    <result property="type" column="type"/>
    <result property="status" column="status"/>
    <result property="isAdmin" column="is_admin"/>
  </resultMap>

  <select id="find" resultMap="resultMap" resultType="dev.odes.fleet.develop.entity.Module">
    SELECT
    <include refid="column"/>
    FROM `develop_module`
    <if test="where != null and where != ''">
      <where>
        ${where}
      </where>
    </if>
    <!--    <if test="order != null and order != ''">-->
    <!--      ORDER BY ${order}-->
    <!--    </if>-->
    <choose>
      <when test="order != null and order != ''">
        ORDER BY ${order}
      </when>
      <otherwise>
        ORDER BY code
      </otherwise>
    </choose>
  </select>

  <select id="findOne" resultMap="resultMap" resultType="dev.odes.fleet.develop.entity.Module">
    SELECT
    <include refid="column"/>
    FROM `develop_module`
    <if test="where != null and where != ''">
      <where>
        ${where}
      </where>
    </if>
    LIMIT 1
  </select>

  <insert id="insertOne" parameterType="dev.odes.fleet.develop.entity.Module">
    INSERT INTO `develop_module`
    (<include refid="insertColumn"/>)
    VALUES
    (<include refid="insertValue"/>)
  </insert>

  <insert id="insertMany" parameterType="java.util.List">
    INSERT INTO `develop_module`
    (<include refid="insertColumn"/>)
    VALUES
    <foreach collection="list" item="module" separator=",">
      (<include refid="insertEntityValue"/>)
    </foreach>
  </insert>

  <update id="updateOne" parameterType="dev.odes.fleet.develop.entity.Module">
    UPDATE `develop_module`
    <include refid="updateColumn"/>
    WHERE id=#{id}
  </update>

  <!--  <update id="updateMany" parameterType="java.util.HashMap">-->
  <!--    UPDATE `module`-->
  <!--    <foreach collection="moduleList" item="module" separator=",">-->
  <!--      <include refid="updateColumn"/>-->
  <!--    </foreach>-->
  <!--    WHERE id=#{id} AND updated_count=#{updatedCount, jdbcType=INTEGER}-->
  <!--  </update>-->

  <update id="deleteOne">
    UPDATE `develop_module`
    <include refid="deleteColumn"/>
    WHERE id=#{id}
  </update>

  <delete id="removeOne" parameterType="java.lang.String">
    DELETE FROM `develop_module` WHERE id=#{id}
  </delete>

  <select id="count" resultType="java.lang.Integer">
    SELECT COUNT(1) FROM `develop_module`
    <if test="where != null and where != ''">
      ${where}
    </if>
    LIMIT 1
  </select>

  <select id="exist" resultType="java.lang.Integer">
    SELECT COUNT(1) FROM `develop_module`
    <if test="where != null and where != ''">
      ${where}
    </if>
    LIMIT 1
  </select>

  <select id="findIndex" resultType="java.lang.Integer">
    SELECT num FROM (
    SELECT D.id, (@row_number:=@row_number+1) as num FROM (SELECT `develop_module`.id FROM `develop_module`
    <if test="where != null and where != ''">
      ${where}
    </if>
    <if test="order != null and order != ''">
      ORDER BY ${order}
    </if>
    ) AS D, (SELECT @row_number:=-1) as T) as A WHERE A.id=#{id} LIMIT 1
  </select>

</mapper>
