#set($moduleCode = $templateContext.module.code.toLowerCase())
#set($modelCode = $templateContext.model.code)
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.odes.fleet.module.${moduleCode}.mapper.${modelCode}Mapper">
  <sql id="tableColumn">
    <trim suffixOverrides=",">
      `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`.`id`,
      `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`.`code`,
      `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`.`name`,
    </trim>
  </sql>
  <sql id="column">
    <trim suffixOverrides=",">
      `id`,
      `code`,
      `name`,
    </trim>
  </sql>

  <sql id="insertColumn">
    <trim suffixOverrides=",">
      `id`,
      <if test="code != null">`code`,</if>
      <if test="name != null">`name`,</if>
    </trim>
  </sql>
  <sql id="insertValue">
    <trim suffixOverrides=",">
      #{id},
      <if test="code != null">#{code},</if>
      <if test="name != null">#{name},</if>
    </trim>
  </sql>
  <sql id="insertEntityValue">
    <trim suffixOverrides=",">
      #{module.id},
      <if test="module.code != null">#{module.code},</if>
      <if test="module.name != null">#{module.name},</if>
    </trim>
  </sql>

  <sql id="updateColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="code != null">`code` = #{code},</if>
      <if test="name != null">`name` = #{name},</if>
    </trim>
  </sql>
  <sql id="updateEntityColumn">
    <trim prefix="set" suffixOverrides=",">
      <if test="module.code != null">`code` = #{module.code},</if>
      <if test="module.name != null">`name` = #{module.name},</if>
    </trim>
  </sql>

  <resultMap id="resultMap" type="dev.odes.fleet.module.${moduleCode}.entity.${modelCode}">
    <id property="id" column="id"/>
    <result property="code" column="code"/>
    <result property="name" column="name"/>
  </resultMap>

  <select id="find" resultMap="resultMap" resultType="dev.odes.fleet.module.${moduleCode}.entity.${modelCode}">
    SELECT
    <include refid="column"/>
    FROM `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    <if test="where != null and where != ''">
      <where>
        ${where}
      </where>
    </if>
    <choose>
      <when test="order != null and order != ''">
        ORDER BY ${order}
      </when>
      <otherwise>
        ORDER BY id DESC
      </otherwise>
    </choose>
  </select>

  <select id="findOne" resultMap="resultMap" resultType="dev.odes.fleet.module.${moduleCode}.entity.${modelCode}">
    SELECT
    <include refid="column"/>
    FROM `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    <if test="where != null and where != ''">
      <where>
        ${where}
      </where>
    </if>
    LIMIT 1
  </select>

  <insert id="insertOne" parameterType="dev.odes.fleet.module.${moduleCode}.entity.${modelCode}">
    INSERT INTO `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    (<include refid="insertColumn"/>)
    VALUES
    (<include refid="insertValue"/>)
  </insert>

  <insert id="insertMany" parameterType="java.util.List">
    INSERT INTO `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    (<include refid="insertColumn"/>)
    VALUES
    <foreach collection="list" item="module" separator=",">
      (<include refid="insertEntityValue"/>)
    </foreach>
  </insert>

  <update id="updateOne" parameterType="dev.odes.fleet.module.${moduleCode}.entity.${modelCode}">
    UPDATE `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    <include refid="updateColumn"/>
    WHERE id=#{id}
  </update>

  <delete id="deleteOne" parameterType="java.lang.String">
    DELETE FROM `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})` WHERE id=#{id}
  </delete>

  <select id="count" resultType="java.lang.Integer">
    SELECT COUNT(1) FROM `${moduleCode}_$templateContext.lowerUnderscore(${modelCode})`
    <if test="where != null and where != ''">
      ${where}
    </if>
    LIMIT 1
  </select>

</mapper>
