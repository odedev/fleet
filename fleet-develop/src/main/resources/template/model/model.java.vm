package dev.odes.fleet.module.${moduleCode}.model;

import dev.odes.fleet.common.model.AbstractModel;
import dev.odes.fleet.module.${moduleCode}.entity.${modelCode};

public class ${modelCode}Model extends AbstractModel<${modelCode}> {
