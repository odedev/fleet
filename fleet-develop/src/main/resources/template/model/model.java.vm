      this.${fieldCode} = ${fieldCode};
    }

    #end
    @Override
    public void fromEntity(${modelCode} ${modelCodeLowerCamel}) {
        if (${modelCodeLowerCamel} == null) {
            return;
        }
    }

    @Override
    public ${modelCode} toEntity() {
        ${modelCode} ${modelCodeLowerCamel} = new ${modelCode}();
        return ${modelCodeLowerCamel};
    }
}
